#!/usr/bin/env zsh

set -o errexit
set -o pipefail

function is_mac() {
  [[ $OSTYPE == darwin*   ]]
}

if is_mac; then
    alias date=gdate
fi

LOG_FILE="$HOME/.local/state/pomodoro/log.jsonl"
NOTIFICATION_FILE="$HOME/.local/state/pomodoro/notification"
if [[ ! -e $LOG_FILE ]]; then
    mkdir -p $(dirname $LOG_FILE)
    touch $LOG_FILE
fi

function start-pomodoro() {
    NOW=$(date "+%s")
    MINUTES="${1:-25}"
    INFO="${2:-DEFAULT}"
    END=$(($NOW + $MINUTES * 60))
    DAY=$(date "+%F")

    # Check if a session is already running
    if [[ -s $LOG_FILE ]]; then
        LAST_END=$(tail -n 1 $LOG_FILE | jq -r '.end')
        if [[ $LAST_END -gt $NOW ]]; then
            REMAINING=$(( $LAST_END - $NOW ))
            FORMATTED=$(date --universal --date "@${REMAINING}" '+%M:%S')
            echo "Pomodoro already running! Time remaining: ${FORMATTED}" >&2
            exit 1
        fi
    fi

    jq -cn '$ARGS.named' --arg end "$END" --arg meta.day "$DAY" --arg meta.text "$INFO" --arg dur "${MINUTES}m" >> $LOG_FILE
    touch $NOTIFICATION_FILE
}

function status-pomodoro() {
    END=$(tail -n 1 $LOG_FILE | jq -r '.end')
    NOW=$(date "+%s")
    RES=$(( $END - $NOW ))
    if [[ $RES -lt 0 ]]; then
        if [[ -e $NOTIFICATION_FILE ]]; then
            rm $NOTIFICATION_FILE
            if ! is_mac; then
                notify-send --urgency=critical --hint=int:transient:1 "­¤Źģ Timer has fired" "Time for a break ŌśĢ"
            fi
        fi
        exit 0;
    fi
    echo -n "\ue003 "
    HOURS=$(date --universal --date "@${RES}" '+%-H')
    if [[ $HOURS -gt 0 ]]; then
        date --universal --date "@${RES}" '+%H:%M:%S Ņé│ '
        exit 0;
    fi
    date --universal --date "@${RES}" '+%M:%S Ņé│ '
}

function edit-pomodoro() {
    $EDITOR $LOG_FILE
}

function stop-pomodoro() {
    if [[ ! -s $LOG_FILE ]]; then
        echo "No pomodoro session found" >&2
        exit 1
    fi

    NOW=$(date "+%s")
    LAST_END=$(tail -n 1 $LOG_FILE | jq -r '.end')

    if [[ $LAST_END -lt $NOW ]]; then
        echo "No pomodoro session currently running" >&2
        exit 1
    fi

    # Rewrite the last line with end set to now
    LAST_LINE=$(tail -n 1 $LOG_FILE)
    ALL_BUT_LAST=$(head -n -1 $LOG_FILE)
    UPDATED_LINE=$(echo $LAST_LINE | jq -c --arg end "$NOW" --argjson stopped true '. + {end: $end, stopped: $stopped}')

    if [[ -n $ALL_BUT_LAST ]]; then
        printf "%s\n%s\n" "$ALL_BUT_LAST" "$UPDATED_LINE" > $LOG_FILE
    else
        printf "%s\n" "$UPDATED_LINE" > $LOG_FILE
    fi

    if [[ -e $NOTIFICATION_FILE ]]; then
        rm $NOTIFICATION_FILE
    fi

    ELAPSED=$(( $NOW - ($LAST_END - $(tail -n 1 $LOG_FILE | jq -r '.dur | gsub("m";"") | tonumber') * 60) ))
    FORMATTED=$(date --universal --date "@${ELAPSED}" '+%M:%S')
    echo "Pomodoro stopped. Elapsed time: ${FORMATTED}"
}

case $1 in
    start)
        start-pomodoro "$2" "$3"
        ;;
    status)
        status-pomodoro
        ;;
    edit)
        edit-pomodoro
        ;;
    stop)
        stop-pomodoro
        ;;
    *)
        printf "unknown command %q" $1
        exit 1;
        ;;
esac
